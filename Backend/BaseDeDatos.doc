-- ----------------------------------------------------------
-- 12) FUNCION PARA GENERAR CODIGO DE INCIDENTE
-- ----------------------------------------------------------

CREATE OR REPLACE FUNCTION fn_generar_codigo_incidente()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.id_incidente IS NULL THEN
        NEW.id_incidente := nextval('incidentes_id_incidente_seq');
    END IF;

    IF NEW.codigo IS NULL OR NEW.codigo = '' THEN
        NEW.codigo := 'INC-' || to_char(NOW(), 'YYYYMMDD') || '-' || lpad(NEW.id_incidente::text, 6, '0');
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_generar_codigo_incidente ON incidentes;
CREATE TRIGGER trg_generar_codigo_incidente
BEFORE INSERT ON incidentes
FOR EACH ROW EXECUTE FUNCTION fn_generar_codigo_incidente();

-- ----------------------------------------------------------
-- 13) FUNCION PARA CALCULAR COMISION 10%
-- ----------------------------------------------------------

CREATE OR REPLACE FUNCTION fn_generar_comision_pago()
RETURNS TRIGGER AS $$
DECLARE
    v_porcentaje NUMERIC(5,2) := 10.00;
BEGIN
    INSERT INTO comisiones_taller (
        id_pago,
        id_taller,
        porcentaje_comision,
        monto_comision,
        estado_comision,
        fecha_generada
    ) VALUES (
        NEW.id_pago,
        NEW.id_taller,
        v_porcentaje,
        ROUND((NEW.monto_servicio * v_porcentaje) / 100.0, 2),
        'PENDIENTE',
        NOW()
    )
    ON CONFLICT (id_pago) DO NOTHING;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_generar_comision_pago ON pagos;
CREATE TRIGGER trg_generar_comision_pago
AFTER INSERT ON pagos
FOR EACH ROW
WHEN (NEW.estado_pago IN ('PENDIENTE', 'PAGADO'))
EXECUTE FUNCTION fn_generar_comision_pago();

