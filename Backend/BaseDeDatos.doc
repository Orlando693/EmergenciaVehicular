)
WHERE r.nombre = 'ADMINISTRADOR'
ON CONFLICT DO NOTHING;

-- ----------------------------------------------------------
-- 15) VISTAS DE REPORTE
-- ----------------------------------------------------------

CREATE OR REPLACE VIEW vw_incidentes_resumen AS
SELECT
    i.id_incidente,
    i.codigo,
    i.fecha_reporte,
    i.estado_actual,
    i.prioridad_actual,
    i.tipo_reportado,
    i.tipo_final,
    c.id_cliente,
    u.nombres || ' ' || u.apellidos AS cliente,
    v.placa,
    t.nombre_comercial AS taller_asignado,
    te.nombres || ' ' || te.apellidos AS tecnico_asignado,
    i.precio_final
FROM incidentes i
JOIN clientes c ON c.id_cliente = i.id_cliente
JOIN usuarios u ON u.id_usuario = c.id_usuario
JOIN vehiculos v ON v.id_vehiculo = i.id_vehiculo
LEFT JOIN (
    SELECT DISTINCT ON (a.id_incidente)
        a.id_incidente,
        a.id_taller,
        a.id_tecnico,
        a.fecha_asignacion
    FROM asignaciones_servicio a
    ORDER BY a.id_incidente, a.fecha_asignacion DESC
) ua ON ua.id_incidente = i.id_incidente
LEFT JOIN talleres t ON t.id_taller = ua.id_taller
LEFT JOIN tecnicos te ON te.id_tecnico = ua.id_tecnico;

CREATE OR REPLACE VIEW vw_metricas_taller AS
SELECT
    t.id_taller,
    t.nombre_comercial,
    (SELECT COUNT(*) FROM solicitudes_taller st WHERE st.id_taller = t.id_taller) AS solicitudes_recibidas,
    (SELECT COUNT(*) FROM solicitudes_taller st WHERE st.id_taller = t.id_taller AND st.estado_solicitud = 'ACEPTADA') AS solicitudes_aceptadas,
    (SELECT COUNT(*)
       FROM asignaciones_servicio a
       JOIN incidentes i ON i.id_incidente = a.id_incidente
      WHERE a.id_taller = t.id_taller
        AND i.estado_actual = 'ATENDIDO') AS servicios_atendidos,
    (SELECT COALESCE(SUM(p.monto_servicio), 0)
       FROM pagos p
      WHERE p.id_taller = t.id_taller
        AND p.estado_pago = 'PAGADO') AS ingresos_generados,
    (SELECT COALESCE(SUM(ct.monto_comision), 0)
       FROM comisiones_taller ct
      WHERE ct.id_taller = t.id_taller
        AND ct.estado_comision IN ('PENDIENTE', 'PAGADA')) AS comision_total
FROM talleres t;

CREATE OR REPLACE VIEW vw_metricas_generales AS
SELECT
    COUNT(*) AS total_incidentes,
    COUNT(*) FILTER (WHERE estado_actual = 'PENDIENTE') AS incidentes_pendientes,
    COUNT(*) FILTER (WHERE estado_actual = 'EN_PROCESO') AS incidentes_en_proceso,
    COUNT(*) FILTER (WHERE estado_actual = 'ATENDIDO') AS incidentes_atendidos,
    COUNT(*) FILTER (WHERE prioridad_actual = 'ALTA') AS prioridad_alta,
    COUNT(*) FILTER (WHERE prioridad_actual = 'MEDIA') AS prioridad_media,
    COUNT(*) FILTER (WHERE prioridad_actual = 'BAJA') AS prioridad_baja,
    COALESCE(AVG(tiempo_estimado_llegada_min), 0) AS promedio_tiempo_llegada_min,
    COALESCE(SUM(precio_final), 0) AS monto_total_servicios
FROM incidentes;

COMMIT;
