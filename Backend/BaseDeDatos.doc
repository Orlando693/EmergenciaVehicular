INSERT INTO rol_permiso (id_rol, id_permiso)
SELECT r.id_rol, p.id_permiso
FROM roles r
JOIN permisos p ON p.codigo IN (
    'auth.login',
    'usuarios.registrar',
    'usuarios.perfil',
    'vehiculos.gestionar',
    'incidentes.reportar',
    'incidentes.consultar_historial',
    'notificaciones.gestionar',
    'mensajes.gestionar',
    'pagos.gestionar'
)
WHERE r.nombre = 'CLIENTE'
ON CONFLICT DO NOTHING;

