# ============================================================
# EmergenciaVehicular Backend — Variables de entorno
# Copia este archivo a .env y completa con tus valores.
# El archivo .env NUNCA debe subirse a git.
# ============================================================

# ── Base de datos ────────────────────────────────────────
# Local PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:TU_PASSWORD@localhost:5432/emergencia_vehicular

# Aiven PostgreSQL (reemplaza TU_PASSWORD con la contraseña real de Aiven):
DATABASE_URL=postgresql+asyncpg://avnadmin:TU_PASSWORD@pg-3bd64a8c-netcrow.l.aivencloud.com:10829/defaultdb

# Activar SSL (obligatorio en Aiven):
DB_SSL_REQUIRED=True

# ── JWT ──────────────────────────────────────────────────
# Genera uno seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_este_secreto_muy_largo_y_seguro_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Aplicación ───────────────────────────────────────────
APP_NAME=EmergenciaVehicular API
APP_VERSION=1.0.0
DEBUG=False

# ── CORS ─────────────────────────────────────────────────
# Lista separada por comas. En producción NUNCA usar "*" si manejas credenciales.
CORS_ORIGINS=https://parcial1si2.web.app

# ── IA Google Gemini ─────────────────────────────────────
# Obtén tu clave gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Almacenamiento de archivos ───────────────────────────
# Carpeta donde se guardan imágenes/audios subidos por los clientes.
# - Local:   public/uploads  (default si no se setea)
# - Railway: /data/uploads   (montar un Volume en /data para persistencia entre deploys)
UPLOAD_DIR=public/uploads
