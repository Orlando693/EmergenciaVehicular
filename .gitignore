dist/
build/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.pytest_cache/
.mypy_cache/
.dmypy.json

# Alembic (versiones compiladas)
*.pyc

